# 2. Automated Cleanup: This removes Excel's quotes and trailing commas
clean_list = []
for line in raw_excel_data.strip().split('\n'):
    # Remove double quotes and the trailing comma
    clean_line = line.replace('"', '').strip().rstrip(',')
    if clean_line:
        # Convert the string "[3, 0]" into a real Python list [3, 0]
        clean_list.append(ast.literal_eval(clean_line))

data = np.array(clean_list)

# 3. Verify data integrity
total_cells = len(data)
print(f"Total cells validated: {total_cells}")

for i, row in enumerate(data):
    if sum(row) != 3:
        print(f"ERROR in Row {i}: Sum is {sum(row)}, not 3. Check your Excel data.")

# 4. Calculate Fleiss' Kappa
kappa = irr.fleiss_kappa(data, method='fleiss')

print(f"\n--- RESULTS ---")
print(f"Fleiss' Kappa Score: {kappa:.3f}")

# 5. Landis & Koch Interpretation
print("Interpretation: ", end="")
if kappa < 0:
    print("Poor agreement")
elif kappa <= 0.20:
    print("Slight agreement")
elif kappa <= 0.40:
    print("Fair agreement")
elif kappa <= 0.60:
    print("Moderate agreement")
elif kappa <= 0.80:
    print("Substantial agreement")
else:
    print("Almost perfect agreement")
