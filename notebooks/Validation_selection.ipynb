import pandas as pd
import numpy as np

# 1. Load your data
df = pd.read_excel("Manual Review of LLM Mappings.csv", sheet_name='LLM mapping')

# 2. Set the Deterministic Seed (makes it reproducible)
np.random.seed(42)

# Create an empty DataFrame to hold our "Validation Mask"
mask_df = pd.DataFrame("", index=df.index, columns=df.columns)
mask_df['Taxonomy ID & Name'] = df['Taxonomy ID & Name']

# Get the list of tools (they start at column index 2)
tools = df.columns[1:]
categories_count = len(df)
tools_count = len(tools)

# 3. Column-wise Sampling (25% of Categories for each Tool)
sample_size_col = max(1, int(categories_count * 0.25)) # e.g., 25% of 32 = 4.8 -> 8 cells
for tool in tools:
    # Randomly pick indices for this column
    sampled_indices = np.random.choice(df.index, size=sample_size_col, replace=False)
    for idx in sampled_indices:
        mask_df.at[idx, tool] = "VALIDATE"

# 4. Row-wise Sampling (25% of Tools for each Category)
sample_size_row = max(1, int(tools_count * 0.25))
for idx in df.index:
    # Randomly pick tools for this row
    sampled_tools = np.random.choice(tools, size=sample_size_row, replace=False)
    for tool in sampled_tools:
        mask_df.at[idx, tool] = "VALIDATE"

# 5. Export the Deterministic Validation Sheet
mask_df.to_csv("Deterministic_Validation_Sample.csv", index=False)
print("Validation sheet generated. Selection locked to Seed 42.")
